{
  "kind": "collectionType",
  "collectionName": "case_studies",
  "info": {
    "singularName": "case-study",
    "pluralName": "case-studies",
    "displayName": "Case Study",
    "description": "Enterprise delivery outcomes and implementation narratives"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "summary": {
      "type": "text",
      "maxLength": 280
    },
    "longDescription": {
      "type": "richtext"
    },
    "status": {
      "type": "enumeration",
      "default": "live",
      "enum": ["live", "beta", "concept", "archived"]
    },
    "visibility": {
      "type": "enumeration",
      "default": "public",
      "enum": ["public", "private"]
    },
    "source": {
      "type": "enumeration",
      "default": "internal",
      "enum": ["internal", "external", "partner"]
    },
    "sourceUrl": {
      "type": "string"
    },
    "sourceName": {
      "type": "string"
    },
    "verified": {
      "type": "boolean",
      "default": false
    },
    "industry": {
      "type": "string"
    },
    "clientName": {
      "type": "string"
    },
    "challenge": {
      "type": "text"
    },
    "solution": {
      "type": "text"
    },
    "outcomes": {
      "type": "text"
    },
    "metrics": {
      "type": "text"
    },
    "keyBenefits": {
      "type": "text"
    },
    "requirements": {
      "type": "text"
    },
    "limitations": {
      "type": "text"
    },
    "exampleWorkflow": {
      "type": "text"
    },
    "timeline": {
      "type": "string"
    },
    "implementationSteps": {
      "type": "text"
    },
    "usageCount": {
      "type": "integer",
      "default": 0
    },
    "rating": {
      "type": "decimal"
    },
    "lastUpdated": {
      "type": "datetime"
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images", "files"]
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag"
    },
    "companies": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::company.company"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "case_studies"
    },
    "useCases": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::use-case.use-case"
    },
    "relatedArticles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::article.article"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
