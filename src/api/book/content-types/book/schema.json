{
  "kind": "collectionType",
  "collectionName": "books",
  "info": {
    "singularName": "book",
    "pluralName": "books",
    "displayName": "Book",
    "description": "Enterprise books and companion artifacts"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "summary": {
      "type": "text",
      "maxLength": 280
    },
    "longDescription": {
      "type": "richtext"
    },
    "status": {
      "type": "enumeration",
      "default": "live",
      "enum": ["live", "beta", "concept", "archived"]
    },
    "visibility": {
      "type": "enumeration",
      "default": "public",
      "enum": ["public", "private"]
    },
    "source": {
      "type": "enumeration",
      "default": "internal",
      "enum": ["internal", "external", "partner"]
    },
    "sourceUrl": {
      "type": "string"
    },
    "sourceName": {
      "type": "string"
    },
    "verified": {
      "type": "boolean",
      "default": false
    },
    "industry": {
      "type": "string"
    },
    "publisher": {
      "type": "string"
    },
    "publishDate": {
      "type": "date"
    },
    "edition": {
      "type": "string"
    },
    "isbn": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "format": {
      "type": "enumeration",
      "default": "digital",
      "enum": ["digital", "print", "audio", "mixed"]
    },
    "pageCount": {
      "type": "integer"
    },
    "readingTime": {
      "type": "string"
    },
    "keyBenefits": {
      "type": "text"
    },
    "useCasesText": {
      "type": "text"
    },
    "limitations": {
      "type": "text"
    },
    "requirements": {
      "type": "text"
    },
    "exampleWorkflow": {
      "type": "text"
    },
    "usageCount": {
      "type": "integer",
      "default": 0
    },
    "rating": {
      "type": "decimal"
    },
    "lastUpdated": {
      "type": "datetime"
    },
    "downloadUrl": {
      "type": "string"
    },
    "previewUrl": {
      "type": "string"
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images", "files"]
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag"
    },
    "companies": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::company.company"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "books"
    },
    "useCases": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::use-case.use-case"
    },
    "relatedArticles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::article.article"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
