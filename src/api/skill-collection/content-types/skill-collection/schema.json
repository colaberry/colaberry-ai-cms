{
  "kind": "collectionType",
  "collectionName": "skill_collections",
  "info": {
    "singularName": "skill-collection",
    "pluralName": "skill-collections",
    "displayName": "Skill Collection",
    "description": "Curated bundles of skills that work together for real-world scenarios"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "text",
      "maxLength": 500
    },
    "category": {
      "type": "string"
    },
    "difficulty": {
      "type": "enumeration",
      "default": "intermediate",
      "enum": [
        "beginner",
        "intermediate",
        "advanced"
      ]
    },
    "keywordTags": {
      "type": "json"
    },
    "skills": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::skill.skill",
      "inversedBy": "skillCollections"
    },
    "coverImageUrl": {
      "type": "string"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    }
  }
}
